# Supabase (Project Settings → API). The anon key is safe to ship; RLS protects data.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Backend (the OpenAI extraction API). In dev this is auto-detected on :3001;
# set this to your Railway URL for production builds.
# EXPO_PUBLIC_API_URL=https://your-backend.up.railway.app
