{
  "expo": {
    "name": "YumiShare",
    "slug": "yumshare",
    "scheme": "yumshare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F6F4"
    },
    "ios": {
      "bundleIdentifier": "com.yumshare.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "YumiShare needs access to your photos so you can set a cover image for a recipe or cookbook.",
        "NSCameraUsageDescription": "YumiShare needs access to your camera so you can take a photo for a recipe or cookbook cover."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C7613C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "YumiShare needs access to your photos so you can set a cover image for a recipe or cookbook.",
          "cameraPermission": "YumiShare needs access to your camera so you can take a photo for a recipe or cookbook cover."
        }
      ],
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "YumiShare needs camera access to scan product barcodes."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          }
        }
      ],
      "expo-audio"
    ]
  }
}
