{
  "expo": {
    "name": "YumiShare",
    "slug": "yumishare",
    "scheme": "yumshare",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F6F4"
    },
    "ios": {
      "bundleIdentifier": "com.yumshare.app",
      "buildNumber": "9",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "YumiShare needs access to your photos so you can set a cover image for a recipe or cookbook.",
        "NSCameraUsageDescription": "YumiShare needs access to your camera so you can take a photo for a recipe or cookbook cover.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C7613C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "YumiShare needs access to your photos so you can set a cover image for a recipe or cookbook.",
          "cameraPermission": "YumiShare needs access to your camera so you can take a photo for a recipe or cookbook cover."
        }
      ],
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "YumiShare needs camera access to scan product barcodes."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-share-intent",
        {
          "disableExperimental": true,
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          }
        }
      ],
      "expo-audio",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "YumiShare uses your location to check the local temperature and suggest how much water to drink."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "f6353ef8-1a4f-47c0-a758-88e03095236b",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ShareExtension",
                  "bundleIdentifier": "com.yumshare.app.share-extension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.yumshare.app"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
